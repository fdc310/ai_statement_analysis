# Tencent Cloud Credentials
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_APPID=

# AES Encryption Key (for request data encryption)
# Key must be 16, 24, or 32 bytes for AES-128/192/256
# IV must be 16 bytes
AES_KEY=c86ade4868d47f2bb43896425ede778a
AES_IV=ac210e0a5e1cfa61

# Request expiration (seconds) - encrypted requests older than this are rejected
REQUEST_EXPIRE_SECONDS=300

# API Server Config
API_HOST=0.0.0.0
API_PORT=8000

# Application Settings
DEBUG=false

# LLM Provider Config (openai / tencent / anthropic)
LLM_PROVIDER=openai
LLM_TIMEOUT=120

# LLM Queue / Rate Limit Config
# All HTTP and WebSocket LLM calls share this process-local queue.
# Maximum number of LLM requests allowed to run at the same time.
LLM_MAX_CONCURRENT=2
# Maximum number of LLM requests allowed to wait in queue.
LLM_QUEUE_MAX_SIZE=100
# Maximum seconds a request may wait for an available LLM slot.
LLM_QUEUE_TIMEOUT=60
# Minimum interval in milliseconds between starting two LLM requests.
LLM_MIN_INTERVAL_MS=500
# Retry count for retryable errors such as 429, timeout, throttling, and 5xx.
LLM_MAX_RETRIES=3
# Initial retry delay in seconds. The delay grows exponentially.
LLM_RETRY_BASE_DELAY=1.0
# Upper bound for exponential retry delay in seconds.
LLM_RETRY_MAX_DELAY=8.0

# Tencent Hunyuan Model Config
TENCENT_MODEL=hunyuan-turbo
TENCENT_MULTIMODAL_MODEL=hunyuan-multimodal

# OpenAI Model Config (optional, for OpenAI-compatible APIs)
OPENAI_MODEL=gpt-4o
OPENAI_MULTIMODAL_MODEL=gpt-4o-audio-preview
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Model Config (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MULTIMODAL_MODEL=claude-sonnet-4-20250514

# Chat Session Config
CHAT_SESSION_TTL=3600

S3_ENDPOINT=http://s3dev.fzfengzhi.cn
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_PREFIX=liaoyu/upload
S3_SECURE=true
S3_PUBLIC_URL=https://liaoyu-public.oss-cn-jjj.aliyuncs.com


# Upload Config (oss / api)
UPLOAD_MODE=api
UPLOAD_API_URL=https://localhost/prod-api/wx/upload
